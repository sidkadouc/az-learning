# Variables nécessaires au worker — copier en .env et remplir.
# AUCUNE clé/secret ici. L'auth est gérée par DefaultAzureCredential (Managed Identity en prod, az login en dev).

STORAGE_BLOB_URL=https://<storage-account>.blob.core.windows.net
STORAGE_QUEUE_URL=https://<storage-account>.queue.core.windows.net
STORAGE_QUEUE_NAME=doc-to-classify
STORAGE_CONTAINER=mailroom

COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE=mailroom
COSMOS_CONTAINER_DOCUMENTS=documents
COSMOS_CONTAINER_CLIENTS=clients

DOC_INTELLIGENCE_ENDPOINT=https://<docintel>.cognitiveservices.azure.com/

FOUNDRY_PROJECT_ENDPOINT=https://<foundry>.services.ai.azure.com/api/projects/mailroom-project
FOUNDRY_MODEL_DEPLOYMENT=gpt-5-mini

CONFIDENCE_THRESHOLD=0.8

APPINSIGHTS_CONNECTION_STRING=
SERVICE_NAME=mailroom-worker
