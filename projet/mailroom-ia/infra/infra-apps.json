    },
    "webIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('uami-web-{0}', parameters('userId'))), '2023-01-31').clientId]"
    },
    "workerIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('uami-worker-{0}', parameters('userId'))), '2023-01-31').clientId]"
    }
  }
