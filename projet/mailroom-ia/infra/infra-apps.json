      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('webAppName')), '2024-10-02-preview').configuration.ingress.fqdn]"
    },
    "webName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "workerJobName": {
